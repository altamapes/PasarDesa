rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - whatsapp: string (required)
    //   - role: string (optional, 'user' or 'admin')
    //   - latitude: number (optional)
    //   - longitude: number (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - sellerId: string (required, immutable)
    //   - sellerName: string (required)
    //   - sellerWhatsapp: string (required)
    //   - name: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - category: string (required)
    //   - imageUrl: string (required)
    //   - images: list of strings (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: products/{productId}/reviews
    // Document ID: {reviewId}
    // Fields:
    //   - userId: string (required, immutable)
    //   - userName: string (required)
    //   - rating: number (required)
    //   - text: string (required)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "altamapes@gmail.com" && request.auth.token.email_verified == true));
    }

    // Domain Validators
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'name', 'whatsapp', 'role', 'latitude', 'longitude', 'createdAt']) &&
             request.resource.data.uid is string &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100 &&
             request.resource.data.whatsapp is string && request.resource.data.whatsapp.size() > 0 && request.resource.data.whatsapp.size() <= 20 &&
             (!('role' in request.resource.data) || (request.resource.data.role in ['user', 'admin'])) &&
             (!('latitude' in request.resource.data) || request.resource.data.latitude is number) &&
             (!('longitude' in request.resource.data) || request.resource.data.longitude is number) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidProduct() {
      return hasOnlyAllowedFields(['sellerId', 'sellerName', 'sellerWhatsapp', 'name', 'description', 'price', 'category', 'imageUrl', 'images', 'createdAt']) &&
             request.resource.data.sellerId is string &&
             request.resource.data.sellerName is string && request.resource.data.sellerName.size() > 0 && request.resource.data.sellerName.size() <= 100 &&
             request.resource.data.sellerWhatsapp is string && request.resource.data.sellerWhatsapp.size() > 0 && request.resource.data.sellerWhatsapp.size() <= 20 &&
             request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 100 &&
             request.resource.data.description is string && request.resource.data.description.size() <= 1000 &&
             request.resource.data.price is number && request.resource.data.price >= 0 &&
             request.resource.data.category is string && request.resource.data.category.size() > 0 && request.resource.data.category.size() <= 50 &&
             request.resource.data.imageUrl is string && request.resource.data.imageUrl.size() <= 500 &&
             (!('images' in request.resource.data) || (request.resource.data.images is list && request.resource.data.images.size() <= 5)) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidReview() {
      return hasOnlyAllowedFields(['userId', 'userName', 'rating', 'text', 'createdAt']) &&
             request.resource.data.userId is string &&
             request.resource.data.userName is string && request.resource.data.userName.size() > 0 && request.resource.data.userName.size() <= 100 &&
             request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
             request.resource.data.text is string && request.resource.data.text.size() <= 1000 &&
             request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if true; // Public profiles so buyers can see seller info if needed
      allow create: if isAuthenticated() && isValidUser() && uidUnchanged() && ((isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == 'user')) || isAdmin());
      allow update: if isAuthenticated() && isValidUser() && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt && ((isOwner(userId) && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true; // Publicly readable products
      allow create: if isAuthenticated() && request.resource.data.sellerId == request.auth.uid && isValidProduct();
      allow update: if isAuthenticated() && isValidProduct() && request.resource.data.createdAt == resource.data.createdAt && ((resource.data.sellerId == request.auth.uid && request.resource.data.sellerId == resource.data.sellerId) || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidReview();
        allow update: if isAuthenticated() && isValidReview() && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.userId == resource.data.userId && resource.data.userId == request.auth.uid;
        allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
